# Copy to .env (or export these) before running `python server.py`.
# The server loads values from the project .env file automatically.

# Required for the Trade Analyst AI panel. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# MODEL=claude-sonnet-4-6     # any current Claude model id
# PORT=8600

# Database settings used by scheduler scripts
# DB_NAME=capstone_db
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
